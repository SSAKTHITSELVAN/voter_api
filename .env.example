# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://voter_user:mugesh@localhost:5432/voter_db

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Super Admin (seeded on first run) ─────────────────────────────────────────
SUPER_ADMIN_PHONE=9000000000
SUPER_ADMIN_PASSWORD=SuperSecret@123
SUPER_ADMIN_NAME=Super Admin

# ── AWS S3 Storage ────────────────────────────────────────────────────────────
USE_S3_ENABLED=false
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
AWS_S3_BUCKET=voter-app-uploads
AWS_S3_REGION=ap-south-1
